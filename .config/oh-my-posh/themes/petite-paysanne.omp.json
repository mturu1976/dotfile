{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{.Folder}}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ if .WSL }}WSL at{{ end }} {{.Icon}} ",
          "foreground": "#F2B29B",
          "background": "#838C3E",
          "type": "os",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "full"
          },
          "template": " {{ .Path }} ",
          "foreground": "#838C3E",
          "powerline_symbol": "\ue0b0",
          "background": "#A7BF4E",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_icon": "\ue0a0 ",
            "branch_identical_icon": "\u25cf",
            "branch_template": "{{ trunc 25 .Branch }}",
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true
          },
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#F2B29B",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#DDDDDD{{ end }}"
          ],
          "powerline_symbol": "\ue0b0",
          "background": "#F2138E",
          "type": "git",
          "style": "powerline",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#F2A341{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#F2138E{{ end }}",
            "{{ if gt .Ahead 0 }}#A7BF4E{{ end }}",
            "{{ if gt .Behind 0 }}#838C3E{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_package_manager": false,
            "npm_icon": " <#838C3E>\ue5fa</> ",
            "yarn_icon": " <#838C3E>\ue6a7</>"
          },
          "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "foreground": "#838C3E",
          "powerline_symbol": "\ue0b0",
          "background": "#F2A341",
          "type": "node",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_version": false
          },
          "template": " \ue235{{ if .Error }}{{ .Error }}{{ else }} {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "foreground": "#838C3E",
          "powerline_symbol": "\ue0b0",
          "background": "#A7BF4E",
          "type": "python",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " \ue7ad {{.Profile}}{{if .Region}}@{{.Region}}{{end}} ",
          "foreground": "#F2B29B",
          "powerline_symbol": "\ue0b0",
          "background": "#838C3E",
          "type": "aws",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "time_format": "15:04"
          },
          "template": " ♥ {{ .CurrentDate | date .Format }} ",
          "foreground": "#838C3E",
          "powerline_symbol": "\ue0b0",
          "background": "#F2B29B",
          "type": "time",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": " \ueba2 {{ .FormattedMs }} ",
          "foreground": "#838C3E",
          "background": "#A7BF4E",
          "type": "executiontime",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
